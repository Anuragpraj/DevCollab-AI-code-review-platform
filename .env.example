# ============================================================
#  DevCollab — Environment Variables
#  1. Copy this file:   cp .env.example .env
#  2. Fill in values below
#  3. Never commit .env to Git
# ============================================================

# ── AI — Required ────────────────────────────────────────────
# Free key at: https://openrouter.ai/keys
# One key → Claude, Gemini, Llama, GPT-4 all accessible
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Database ──────────────────────────────────────────────────
# For local Docker: leave as-is
# For Render: set DATABASE_URL to your Render Postgres connection string
DATABASE_URL=jdbc:postgresql://localhost:5432/devcollab
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ── Security ──────────────────────────────────────────────────
# Change this to any long random string in production
JWT_SECRET=devcollab-super-secret-jwt-key-change-in-production-min-32-chars

# ── CORS — add your Render frontend URL after deploy ─────────
# Example: CORS_ALLOWED_ORIGINS=http://localhost:3000,https://devcollab-frontend.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
